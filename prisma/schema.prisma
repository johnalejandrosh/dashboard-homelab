generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enlace {
  id          Int     @id @default(autoincrement())
  nombre      String
  url         String
  descripcion String?
  favorito    Boolean @default(false)

  @@map("enlaces")
}

model Acceso {
  id            Int      @id @default(autoincrement())
  proyecto      String   @default("General")
  servicio      String?
  entorno       String?
  descripcion   String?
  contenido     String
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("accesos")
}
