generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enlace {
  id          Int     @id @default(autoincrement())
  nombre      String
  url         String
  descripcion String?
  favorito    Boolean @default(false)

  @@map("enlaces")
}
